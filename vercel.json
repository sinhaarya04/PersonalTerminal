{
  "rewrites": [
    { "source": "/yf/(.*)", "destination": "/api/yf?path=/$1" },
    { "source": "/gnews/(.*)", "destination": "/api/gnews?path=/$1" },
    { "source": "/arxiv/(.*)", "destination": "/api/proxy?svc=arxiv&path=/$1" },
    { "source": "/semscholar/(.*)", "destination": "/api/proxy?svc=semscholar&path=/$1" },
    { "source": "/fred/(.*)", "destination": "/api/fred?path=/$1" },
    { "source": "/rssproxy", "destination": "/api/proxy?svc=rss" },
    { "source": "/ytlive", "destination": "/api/proxy?svc=ytlive" },
    { "source": "/coingecko/(.*)", "destination": "/api/coingecko?path=/$1" },
    { "source": "/defillama/(.*)", "destination": "/api/defillama?path=/$1" },
    { "source": "/polymarket/(.*)", "destination": "/api/polymarket?path=/$1" },
    { "source": "/sec/(.*)", "destination": "/api/sec?path=/$1" },
    { "source": "/worldbank/(.*)", "destination": "/api/worldbank?path=/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
