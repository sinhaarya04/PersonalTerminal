{
  "rewrites": [
    { "source": "/yf/(.*)", "destination": "/api/yf?path=/$1" },
    { "source": "/gnews/(.*)", "destination": "/api/gnews?path=/$1" },
    { "source": "/arxiv/(.*)", "destination": "/api/arxiv?path=/$1" },
    { "source": "/semscholar/(.*)", "destination": "/api/semscholar?path=/$1" },
    { "source": "/fred/(.*)", "destination": "/api/fred?path=/$1" },
    { "source": "/rssproxy", "destination": "/api/rssproxy" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
